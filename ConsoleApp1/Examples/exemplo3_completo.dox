// Exemplo 3: soma de 1 ate n, com strings, while, aritmetica e if/else
int n = 5;
int soma = 0;
int i = 1;

// Soma 1 + 2 + 3 + 4 + 5
while (i < n + 1) {
    soma = soma + i;
    i = i + 1;
}

print("Soma de 1 ate n:");
print(soma);

// Testa se a soma passou de 10
bool grande = soma > 10;
if (grande) {
    print("A soma e grande!");
} else {
    print("A soma e pequena.");
}
